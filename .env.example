# Supabase（填入下列三项并把 DATA_SOURCE 改为 supabase 即切换到云端数据库）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 数据源开关：mock | supabase（缺省 mock；选 supabase 时需配置上面三项）
DATA_SOURCE=mock

# TTS 服务（选一，未配置则前端走 Web Speech API 降级）
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastasia
# GOOGLE_TTS_API_KEY=

# 管理员配置
ADMIN_HINT_DAILY_LIMIT=10
